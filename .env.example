# Cortex — .env.example
# Copy to .env and fill in all values marked REQUIRED.
# NEVER commit .env to git.
# Use Docker secrets or AWS Secrets Manager in production.

# ─────────────────────────────────────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────────────────────────────────────
VERSION=1.4.0
ENVIRONMENT=development            # development | staging | production

# ─────────────────────────────────────────────────────────────────────────────
# SECURITY  (REQUIRED)
# ─────────────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_USE_A_RANDOM_64_CHAR_HEX_STRING_HERE_000000000000000000

# Comma-separated allowed CORS origins
ALLOWED_ORIGINS=["http://localhost:3000","https://app.cortex.yourdomain.com"]

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE  (REQUIRED)
# ─────────────────────────────────────────────────────────────────────────────
POSTGRES_USER=cortex
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=cortex_db
DATABASE_URL=postgresql+asyncpg://cortex:CHANGE_ME_DB_PASSWORD@postgres:5432/cortex_db
DATABASE_URL_SYNC=postgresql+psycopg2://cortex:CHANGE_ME_DB_PASSWORD@postgres:5432/cortex_db

# ─────────────────────────────────────────────────────────────────────────────
# REDIS  (REQUIRED)
# ─────────────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0
CELERY_RESULT_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0

# ─────────────────────────────────────────────────────────────────────────────
# AWS / STORAGE  (REQUIRED for production)
# ─────────────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=ap-south-1
S3_BUCKET=cortex-inspections

# ─────────────────────────────────────────────────────────────────────────────
# RATE LIMITING
# ─────────────────────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=120

# ─────────────────────────────────────────────────────────────────────────────
# OBSERVABILITY  (optional but strongly recommended)
# ─────────────────────────────────────────────────────────────────────────────
SENTRY_DSN=https://your_key@sentry.io/your_project_id

FLOWER_USER=admin
FLOWER_PASSWORD=CHANGE_ME_FLOWER_PASSWORD

GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# ─────────────────────────────────────────────────────────────────────────────
# EXTERNAL APIS  (required for full pipeline)
# ─────────────────────────────────────────────────────────────────────────────
BLACKBOX_API_ENDPOINT=https://api.your-detection-service.com/detect
BLACKBOX_API_KEY=your_api_key_here
